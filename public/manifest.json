{
	"author": "Zachary Berk",
	"manifest_version": 3,
	"name": "CLC Billing Automation",
	"version": "1.1.0.0",
	"description": "Automates invoice processing from TherapyNotes to QuickBooks",
	"permissions": ["storage", "tabs"],
	"background": {
		"service_worker": "background.js"
	},
	"host_permissions": [
		"*://*.therapynotes.com/*",
		"*://qbo.intuit.com/*",
		"*://*.intuitcdn.net/*"
	],
	"content_scripts": [
		{
			"matches": [
				"*://*.therapynotes.com/*",
				"*://qbo.intuit.com/*",
				"*://*.intuitcdn.net/*"
			],
			"js": ["main.js"],
			"all_frames": true,
			"run_at": "document_idle"
		}
	],
	"icons": {		
		"128": "icons/icon128.png"
	}
}
